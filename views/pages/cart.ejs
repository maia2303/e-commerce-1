<body>
    <%- include('../partials/header') %>

    <main>
        <section class="cart-container">
            <h1>Tu carrito</h1>

            <% if (cart.length > 0) { %>
                <div class="cart-items">
                    <% 
                    const groupedCart = cart.reduce((acc, product) => {
                        if (!acc[product.id]) {
                            acc[product.id] = { ...product, quantity: 0 };
                        }
                        acc[product.id].quantity += product.quantity;
                        return acc;
                    }, {});
                    const uniqueCart = Object.values(groupedCart);
                    %>
                    <% uniqueCart.forEach(product => { %> 
                        <article class="cart-item">
                            <img src="<%= product.imagen %>" alt="<%= product.nombre %>">
                            <div class="item-details">
                                <h2><%= product.nombre %></h2>
                                <p>Precio unitario: <%= product.precio %> puntos</p>
                            </div>

                            <div class="quantity-controls">
                                <form action="/cart/decrease/<%= product.id %>" method="POST">
                                    <button type="submit" class="btn-qty">-</button>
                                </form>

                                <span class="qty-number"><%= product.quantity %></span>

                                <form action="/cart/increase/<%= product.id %>" method="POST">
                                    <button type="submit" class="btn-qty">+</button>
                                </form>
                            </div>

                            <p class="item-subtotal">
                                <strong>Subtotal:</strong> <%= product.precio * product.quantity %> puntos
                            </p>
                        </article>
                    <% }); %>
                </div>

                <hr>

                <div class="cart-summary">
                    <section class="coupon-section">
                        <h3>¿Tienes un cupón?</h3>
                        <form action="/cart/coupon" method="POST">
                            <input 
                                type="text" 
                                name="coupon" 
                                placeholder="Ej: DESCUENTO10"
                                aria-label="Código de descuento"
                            >
                            <button type="submit">Aplicar</button>
                        </form>
                    </section>

                    <section class="totals-section">
                        <% if (descuento > 0) { %>
                            <p>Descuento aplicado: <span class="discount-badge">-<%= descuento %>%</span></p>
                        <% } %>
                        <p class="final-total">Total a pagar: <strong><%= total %> puntos</strong></p>
                    </section>
                </div>

                <div class="cart-actions">
                    <a href="/checkout" class="btn-primary">Ir a pagar</a>
                    <a href="/" class="btn-secondary">Seguir comprando</a>
                </div>

            <% } else { %>
                <div class="empty-cart">
                    <p>No tienes productos en tu carrito aún.</p>
                    <a href="/" class="btn-primary">Ver productos</a>
                </div>
            <% } %>

        </section>
    </main>

    <%- include('../partials/footer') %>
</body>