<%- include('../partials/header') %>
<main>
    <h1 class = "productoNombre"><%= product.nombre %></h1>
    <img src="<%= product.imagen %>" alt="<%= product.nombre %>">
    <p><%= product.precio %> puntos</p>
    <p><%= product.descripcion %></p>
    <!--hacer logica para que se guarde-->

    <form action="/agregar-carrito" method="post">
        <input type="hidden" name="idProducto" value="<%= product.id %>">
            <button>Agregar al Carrito</button>
    </form>
</main>

<% if (locals.success) { %>
    <div class="alerta-exito">¡Producto agregado al carrito con éxito!</div>
<% } %>


<div class="puedeInteresar">
    <h2>Productos Relacionados</h2>
    <div class="product-list">
        <% if (locals.productosRelacionados) { %>
            <% productosRelacionados.slice(0, 4).forEach(p => { %> <!-- Muestra solo los primeros 4 productos -->
                <%- include('../partials/productCard') %>
            <% }); %>
        <% } %>
    </div>
</div>
<%- include('../partials/categorias') %>
<%- include('../partials/footer') %>